# Stellar secret key (S...) used by the relayer to sign transactions.
RELAYER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Allowlist source ---
# Pick exactly one path:
#
# (1) Default (deployed): the relayer fetches the cumulative
#     contracts-manifest.json from onymchat/onym-contracts on startup
#     and on a periodic timer. The manifest contains every historical
#     release's contracts, not just the latest tag. Override the URL
#     here if you're testing against a fork or a staging build.
# RELAYER_CONTRACTS_MANIFEST_URL=https://github.com/onymchat/onym-contracts/releases/latest/download/contracts-manifest.json
# RELAYER_CONTRACTS_MANIFEST_REFRESH_SECS=900
# RELAYER_MANIFEST_CACHE_PATH=/var/lib/onym-relayer/manifest-cache.json
#
# (2) Static override (offline / dev): set RELAYER_CONTRACT_ALLOWLIST
#     and the relayer skips the remote fetch entirely. Useful for
#     local tests where you don't want a live HTTPS dependency.
# RELAYER_CONTRACT_ALLOWLIST='{"testnet":{"anarchy":["CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"],"oneonone":[],"democracy":[],"oligarchy":[],"tyranny":[]},"public":{"anarchy":[],"oneonone":[],"democracy":[],"oligarchy":[],"tyranny":[]}}'

# Per-network Soroban RPC endpoints. Defaults are Stellar public infrastructure.
RELAYER_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
RELAYER_PUBLIC_RPC_URL=https://soroban.stellar.org

# Optional per-network passphrase overrides.
RELAYER_TESTNET_NETWORK_PASSPHRASE='Test SDF Network ; September 2015'
RELAYER_PUBLIC_NETWORK_PASSPHRASE='Public Global Stellar Network ; September 2015'

# Bind address for the HTTP server.
RELAYER_BIND=127.0.0.1:8080

# Comma-separated bearer tokens. Empty disables auth on `/`. Required
# (non-empty) to enable `POST /admin/refresh` and `set_restricted_mode`.
# Onym-contracts release.yml uses one of these as RELAYER_REFRESH_TOKEN.
RELAYER_AUTH_TOKENS=

# Rate limit per minute per IP.
RELAYER_RATE_LIMIT=30

# Maximum request payload size in bytes.
RELAYER_MAX_PAYLOAD_SIZE=8192

# Legacy fallback: when RELAYER_CONTRACT_ALLOWLIST is unset and any of
# the RELAYER_*_CONTRACT_ID vars below are set, those drive the
# allowlist instead and remote-manifest fetching is disabled.
# RELAYER_NETWORK=testnet
# RELAYER_RPC_URL=https://soroban-testnet.stellar.org
# RELAYER_NETWORK_PASSPHRASE='Test SDF Network ; September 2015'
# RELAYER_ANARCHY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# RELAYER_ONEONONE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# RELAYER_DEMOCRACY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# RELAYER_OLIGARCHY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# RELAYER_TYRANNY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
